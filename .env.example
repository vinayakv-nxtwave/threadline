# PostgreSQL connection string
DATABASE_URL=postgres://user:password@localhost:5432/threadline

# Your Whapi.Cloud channel API token (found on the channel page in your Whapi dashboard)
WHAPI_TOKEN=your_whapi_channel_token

# A random string you choose yourself. Append it to the webhook URL you give Whapi
# so random internet traffic can't POST fake messages into your ticket queue.
WEBHOOK_SECRET=choose_a_long_random_string

PORT=3000
